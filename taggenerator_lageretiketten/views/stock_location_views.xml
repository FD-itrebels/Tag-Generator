<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Hierarchical List View -->
        <record id="view_stock_location_list" model="ir.ui.view">
            <field name="name">stock.location.list</field>
            <field name="model">stock.location</field>
            <field name="arch" type="xml">
                <list string="Warehouse Locations">
                    <field name="name"/>
                    <field name="barcode"/>
                    <field name="usage"/>
                    <field name="location_id"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_stock_location_search" model="ir.ui.view">
            <field name="name">stock.location.search</field>
            <field name="model">stock.location</field>
            <field name="arch" type="xml">
                <search string="Warehouse Locations">
                    <field name="name" string="Name"/>
                    <field name="barcode" string="Barcode"/>
                    <field name="usage" string="Type"/>
                    <separator/>
                    <filter name="filter_internal" string="Internal" domain="[('usage','=','internal')]"/>
                    <filter name="filter_view" string="View" domain="[('usage','=','view')]"/>
                    <filter name="filter_lageretiketten" string="Test Warehouse" domain="[('barcode','ilike','LAGER_ROOT_TEST')]"/>
                </search>
            </field>
        </record>

        <!-- Action zu Stock Location -->
        <record id="action_stock_location_view" model="ir.actions.act_window">
            <field name="name">Warehouse Locations</field>
            <field name="res_model">stock.location</field>
            <field name="view_mode">list</field>
            <field name="view_ids" eval="[(0,0,{'view_mode': 'list', 'view_id': ref('view_stock_location_list')})]"/>
            <field name="search_view_id" ref="view_stock_location_search"/>
            <field name="target">current</field>
        </record>

    </data>
</odoo>
