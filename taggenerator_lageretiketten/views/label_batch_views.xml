<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record id="view_label_batch_list" model="ir.ui.view">
            <field name="name">label.batch.list</field>
            <field name="model">label.batch</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="state"/>
                    <field name="record_count"/>
                    <field name="group_count"/>
                    <field name="created_by"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>
        
        <!-- Form View -->
        <record id="view_label_batch_form" model="ir.ui.view">
            <field name="name">label.batch.form</field>
            <field name="model">label.batch</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_generate_pdf" type="object" string="🎨 PDF generieren" class="btn-primary"/>
                        <button name="action_download_pdf" type="object" string="⬇️ PDF herunterladen"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" class="oe_inline"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="source_type" widget="radio"/>
                            </group>
                        </group>
                        
                        <!-- CSV Source -->
                        <group string="📄 CSV-Datei">
                            <field name="csv_file" widget="binary" filename="csv_filename"/>
                            <field name="csv_filename" invisible="1"/>
                        </group>
                        
                        <!-- Odoo Source -->
                        <group string="🗂️ Odoo Locations">
                            <field name="location_id" options="{'no_create': False}"/>
                        </group>
                        
                        <!-- General Info -->
                        <group>
                            <group>
                                <field name="created_by" readonly="1"/>
                                <field name="create_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="state" readonly="1"/>
                                <field name="record_count" readonly="1"/>
                                <field name="group_count" readonly="1"/>
                                <field name="save_pdf"/>
                            </group>
                        </group>
                        
                        <group string="Output">
                            <field name="pdf_file" widget="binary" filename="pdf_filename" readonly="1"/>
                            <field name="pdf_filename" readonly="1"/>
                        </group>
                        <group string="Fehlerinfo">
                            <field name="error_message" readonly="1" widget="text"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <!-- Action -->
        <record id="action_label_batch_list" model="ir.actions.act_window">
            <field name="name">Etikettenblöcke</field>
            <field name="res_model">label.batch</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Keine Etikettenblöcke gefunden</p>
                <p>Laden Sie eine CSV mit Lagerdaten hoch und generieren Sie Batch-PDFs.</p>
            </field>
        </record>
    </data>
</odoo>
